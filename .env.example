# 数据模式: tt(走Tushare API) 或 websearch(走网络搜索)
# 不配置或设为 websearch 时，纯对话模式，不调用外部接口
DATA_MODE=websearch

# Tushare API 配置（DATA_MODE=tt 时必须填写）
# 前往 https://tushare.pro/user/token 注册获取 Token
TUSHARE_TOKEN=你的56位Tushare Token

# 本地数据目录（可选，L2 降级使用，不配置则跳过本地回退）
# 支持格式: Parquet 文件，按以下目录结构组织：
#   {STOCK_DATA_DIR}/
#     daily_raw/      # 日线 OHLCV，每只股票一个 .parquet 文件（如 601456.SH.parquet）
#     stock_basic/    # 股票基本信息 stock_list.parquet（含 ts_code, name 列）
#     financial/      # 财务数据（可选）
#     adj_factor/     # 复权因子（可选）
# 示例路径（Windows）: D:/stock_data
# 示例路径（macOS/Linux）: /Users/xxx/stock_data
STOCK_DATA_DIR=
