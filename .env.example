# 数据模式: tt(走Tushare API) 或 websearch(走网络搜索)
# 不配置或设为 websearch 时，纯对话模式，不调用外部接口
DATA_MODE=websearch

# Tushare API 配置（DATA_MODE=tt 时必须填写）
# 前往 https://tushare.pro/user/token 注册获取 Token
TUSHARE_TOKEN=你的56位Tushare Token

# 本地数据目录（可选，L2 降级使用，不配置则跳过本地回退）
# 支持格式: Parquet 文件，按以下目录结构组织：
#   {STOCK_DATA_DIR}/
#     daily_raw/      # 日线 OHLCV，每只股票一个 .parquet 文件（如 601456.SH.parquet）
#     stock_basic/    # 股票基本信息 stock_list.parquet（含 ts_code, name 列）
#     financial/      # 财务数据（可选）
#     adj_factor/     # 复权因子（可选）
# 示例路径（Windows）: D:/stock_data
# 示例路径（macOS/Linux）: /Users/xxx/stock_data
STOCK_DATA_DIR=

# ─────────────────────────────────────────────────────────────
# B1 选股参数（P0 移植：原硬编码阈值全部可配置，以下为可选覆盖）
# 不配置则使用括号内默认值
# ─────────────────────────────────────────────────────────────
# B1_J_THRESHOLD=-8            # J 值阈值（J 必须 <= 此值才进候选）
# B1_J_BLUNT_FLOOR=-3          # 近10日J均低于此值→钝化排除（超卖衰竭不买）
# B1_GREEN_BRICK_LIMIT=4       # 近4日阴线数 >= 此值→绿砖状态排除
# B1_VOL_RATIO_MAX=0.85        # 量比必须 < 此值（缩量回调）
# B1_DEV_MA20_BELOW=-3         # 乖离MA20必须 <= 此值(%)，价在均线下方
# B1_DROP_10D_MIN=-25          # 10日跌幅必须 >= 此值(%)，排除崩盘股
# B1_PRICE_MIN=3               # 最低股价（排除仙股）
# B1_RSI6_CEILING=25           # MDC: RSI6 < 此值→超卖加分
# B1_ADX_FLOOR=40              # MDC: ADX > 此值→动能竭尽加分
# B1_SANDGLASS_MIN=50          # 硬过滤: 沙漏评分 < 此值→一票否决（审美太差）
# B1_CENTIPEDE_MAX=60          # 硬过滤: 蜈蚣图评分 >= 此值→一票否决（呼吸紊乱）

